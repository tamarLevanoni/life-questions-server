# === Application ===
NODE_ENV=development
PORT=3001

# === Security ===
# Shared secret validated on every inbound request from the Next.js BFF
API_SECRET=your-strong-random-secret-here

# === Database (Neon PostgreSQL) ===
# Pooled connection string (used at runtime)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# === Neon Direct URL ===
# Non-pooled connection string (used for Prisma migrations only)
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# === CORS ===
CORS_ORIGIN_DEV=http://localhost:3000
CORS_ORIGIN_PROD=https://your-production-frontend.vercel.app

# === Sentry ===
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
